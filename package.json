{
  "name": "@adminforth/connector-mysql",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "homepage": "https://adminforth.dev/docs/tutorial/Plugins/connector-mysql/",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc"
  },
  "keywords": [
    "adminforth",
    "ai-agent",
    "tool-calling",
    "chat-ui",
    "langgraph",
    "llm",
    "session-memory"
  ],
  "author": "DevForth (https://devforth.io)",
  "license": "MIT",
  "description": "AI agent plugin for AdminForth with tool-based workflows and persistent chat sessions",
  "devDependencies": {
    "@types/node": "latest",
    "adminforth": "^3.2.7",
    "semantic-release": "^24.2.1",
    "semantic-release-slack-bot": "^4.0.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "bson": "^7.2.0",
    "dayjs": "^1.11.21",
    "mysql2": "^3.14.2"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "semantic-release-slack-bot",
        {
          "packageName": "@adminforth/connector-mysql",
          "notifyOnSuccess": true,
          "notifyOnFail": true,
          "slackIcon": ":package:",
          "markdownReleaseNotes": true
        }
      ]
    ]
  },
  "branches": [
    "main",
    {
      "name": "next",
      "prerelease": true
    }
  ],
  "peerDependencies": {
    "adminforth": "^3.2.6"
  }
}
